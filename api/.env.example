# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Docker Compose already define this — only change if using an external DB.
DATABASE_URL="postgresql://user:password@localhost:5432/polygekko"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ─── Polymarket Wallet ────────────────────────────────────────────────────────
#
# PRIVATE_KEY
#   The private key of the EOA that OWNS your Polymarket proxy wallet.
#   If you created your account via the Polymarket website, this is the
#   embedded wallet key — export it from:
#     Polymarket → Avatar → Wallet → Export Key (or Export Private Key)
#   Format: 64 hex chars (with or without 0x prefix — both accepted).
#   ⚠️  NEVER share or commit this value.
#
PRIVATE_KEY=your_64_hex_private_key_here

#
# PROXY_WALLET_ADDRESS_MAIN
#   The address of your Polymarket proxy wallet (Safe).
#   This is the address shown on your Polymarket profile URL:
#     https://polymarket.com/profile/0xYOUR_PROXY_ADDRESS
#   ⚠️  This is NOT the same as the EOA address derived from PRIVATE_KEY.
#   Format: 0x + 40 hex chars.
#
PROXY_WALLET_ADDRESS_MAIN=0x_your_proxy_wallet_address_here

#
# SIGNATURE_TYPE
#   How orders are signed. Must match how your proxy wallet was created:
#     0 = EOA            — plain wallet, no proxy (uncommon for Polymarket)
#     1 = POLY_PROXY     — standard Polymarket proxy wallet (most traders)
#     2 = POLY_GNOSIS_SAFE — Safe wallet via builder-relayer (market makers)
#   If you deployed your wallet using the builder-relayer-client → use 2.
#   If you created your wallet through the Polymarket website (or activated
#   the relayer via the Polymarket interface) → use 1.
#
SIGNATURE_TYPE=1

# ─── Polygon RPC ─────────────────────────────────────────────────────────────
#
# POLYGON_RPC_URL
#   Polygon mainnet JSON-RPC endpoint used to read USDC balance.
#   Free public endpoint works but may be rate-limited.
#   For reliability, create a free app on:
#     - Alchemy:   https://dashboard.alchemy.com  → Create App → Polygon Mainnet
#     - QuickNode: https://www.quicknode.com       → Create Endpoint → Polygon
#     - Ankr:      https://www.ankr.com/rpc        → Polygon (free tier available)
#
POLYGON_RPC_URL=https://polygon-rpc.com
