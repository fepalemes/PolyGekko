{
  "name": "polygekko",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "api",
    "web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run start:dev --workspace=api",
    "dev:web": "npm run dev --workspace=web",
    "build": "npm run build --workspace=api && npm run build --workspace=web",
    "db:migrate": "npm run prisma:migrate --workspace=api",
    "db:generate": "npm run prisma:generate --workspace=api",
    "db:studio": "npm run prisma:studio --workspace=api"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
