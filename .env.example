# =============================================================================
# PolyGekko - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE (external — configure with your existing Postgres IP/credentials)
# =============================================================================
DATABASE_URL="postgresql://user:password@<IP>:5432/polygekko"

# =============================================================================
# WALLET & BLOCKCHAIN
# =============================================================================
# EOA private key (signing only — never holds USDC directly)
PRIVATE_KEY=your_private_key_here

# Polymarket proxy wallet address (where USDC is deposited)
PROXY_WALLET_ADDRESS=your_proxy_wallet_address

# Polygon RPC endpoint
POLYGON_RPC_URL=https://polygon-rpc.com

# =============================================================================
# API SERVER
# =============================================================================
PORT=3001

# =============================================================================
# FRONTEND
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================================================
# DOCKER (override for production)
# =============================================================================
# NEXT_PUBLIC_API_URL=https://api.your-domain.com
